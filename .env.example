# =============================================================================
# Multi-Agent RevOps Orchestrator - Environment Configuration
# Copy this file to .env and fill in your secrets
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic Claude (Primary LLM for all agents)
# Model: claude-sonnet-4-20250514 (or latest Claude 3.5/4 Sonnet)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# PostgreSQL Database (Internal Revenue Data Store)
# Use docker-compose for local development: postgres://revops:revops@postgres:5432/revops
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://revops:revops@localhost:5432/revops
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Redis (State Persistence & Caching between agent runs)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# WhatsApp Cloud API (Router Agent Delivery)
# Get credentials from Meta for Developers → WhatsApp → API Setup
# -----------------------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_API_VERSION=v21.0
WHATSAPP_RECIPIENT_PHONE=+14155552671   # E.164 format, e.g. +14155552671
WHATSAPP_ENABLED=true

# -----------------------------------------------------------------------------
# SMTP / Email (Router Agent - SendGrid or any SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM_EMAIL=revops@yourcompany.com
SMTP_FROM_NAME="RevOps Intelligence"
SMTP_TO_EMAILS=founder@company.com,head-of-sales@company.com
SMTP_USE_TLS=true
EMAIL_ENABLED=true

# -----------------------------------------------------------------------------
# Scheduler (Weekly Cron)
# -----------------------------------------------------------------------------
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Kolkata
SCHEDULER_WEEKLY_CRON=0 9 * * MON   # Every Monday at 09:00 local time

# -----------------------------------------------------------------------------
# FastAPI Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_TITLE="Multi-Agent RevOps Orchestrator"
API_VERSION="1.0.0"

# -----------------------------------------------------------------------------
# Logging & Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Demo / Development Flags
# -----------------------------------------------------------------------------
DEMO_MODE=false                    # If true, uses mock scraping + mock delivery
MAX_SCRAPER_RETRIES=2
ENABLE_STATE_LOGGING=true

# -----------------------------------------------------------------------------
# Optional: LangSmith Tracing (highly recommended for agent debugging)
# -----------------------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=multi-agent-revops-orchestrator
